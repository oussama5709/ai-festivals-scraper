{
  "title": "AI Festivals & Conferences Scraper",
  "description": "Intelligent scraper for AI events worldwide",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchRegions": {
      "title": "Search Regions",
      "description": "Select regions to search for events",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "worldwide",
          "middle-east",
          "africa",
          "europe",
          "asia",
          "americas"
        ]
      },
      "default": ["worldwide"],
      "minItems": 1
    },
    "maxResults": {
      "title": "Maximum Results",
      "description": "Maximum number of events to return (10-1000)",
      "type": "integer",
      "minimum": 10,
      "maximum": 1000,
      "default": 100
    },
    "upcomingOnly": {
      "title": "Upcoming Events Only",
      "description": "Return only upcoming events",
      "type": "boolean",
      "default": true
    },
    "minDate": {
      "title": "Minimum Date",
      "description": "Minimum date for events (YYYY-MM-DD format)",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "default": ""
    },
    "includeEventTypes": {
      "title": "Event Types",
      "description": "Types of events to include",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "conference",
          "workshop",
          "meetup",
          "webinar",
          "summit",
          "hackathon",
          "course"
        ]
      },
      "default": ["conference", "workshop"]
    },
    "sortBy": {
      "title": "Sort By",
      "description": "How to sort results",
      "type": "string",
      "enum": [
        "relevance",
        "date",
        "popularity"
      ],
      "default": "relevance"
    }
  },
  "required": ["searchRegions"]
}
